{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "list-analytics-dashboard-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/listAnalyticsDashboard/ListAnalyticsDashboardWebPart.js",
          "manifest": "./src/webparts/listAnalyticsDashboard/ListAnalyticsDashboardWebPart.manifest.json"
        }
      ]
    },
    "request-approval-hub-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/requestApprovalHub/RequestApprovalHubWebPart.js",
          "manifest": "./src/webparts/requestApprovalHub/RequestApprovalHubWebPart.manifest.json"
        }
      ]
    },
    "project-health-board-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/projectHealthBoard/ProjectHealthBoardWebPart.js",
          "manifest": "./src/webparts/projectHealthBoard/ProjectHealthBoardWebPart.manifest.json"
        }
      ]
    },
    "onboarding-command-center-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/onboardingCommandCenter/OnboardingCommandCenterWebPart.js",
          "manifest": "./src/webparts/onboardingCommandCenter/OnboardingCommandCenterWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "ListAnalyticsDashboardWebPartStrings": "lib/webparts/listAnalyticsDashboard/loc/{locale}.js",
    "RequestApprovalHubWebPartStrings": "lib/webparts/requestApprovalHub/loc/{locale}.js",
    "ProjectHealthBoardWebPartStrings": "lib/webparts/projectHealthBoard/loc/{locale}.js",
    "OnboardingCommandCenterWebPartStrings": "lib/webparts/onboardingCommandCenter/loc/{locale}.js",
    "PropertyControlStrings": "node_modules/@pnp/spfx-property-controls/lib/loc/{locale}.js"
  }
}
